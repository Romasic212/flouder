<Window x:Class="flouder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SyncApp" Height="400" Width="400">

    <StackPanel Margin="10">

        <Button Click="BtnSelectFolder_Click">
            Выбрать папку
        </Button>

        <TextBlock Name="TxtFolder" Margin="0,10,0,10"/>

        <TextBox Name="TxtIP" Width="150" Margin="0,5"/>
        <Button Click="BtnConnect_Click">
            Подключиться
        </Button>

        <ListBox Name="FilesList" Margin="0,10,0,0"/>

    </StackPanel>
</Window>
